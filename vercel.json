{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci && cd frontend && NODE_OPTIONS=--disable-warning=DEP0040 npm ci",
  "buildCommand": "cd frontend && NODE_OPTIONS=--disable-warning=DEP0040 npm run build",
  "outputDirectory": "site",
  "framework": null,
  "env": {
    "NODE_OPTIONS": "--disable-warning=DEP0040"
  },
  "build": {
    "env": {
      "NODE_OPTIONS": "--disable-warning=DEP0040"
    }
  },
  "crons": [
    {
      "path": "/api/crm/dashboard-warm-cron",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/crm/meili-sync-cron",
      "schedule": "30 4 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "connect-intel-mocha.vercel.app" }],
      "destination": "https://connectintel.net/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.connectintel.net" }],
      "destination": "https://connectintel.net/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/workbox-:hash.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api?path=$1" },
    { "source": "/setup-dns", "destination": "/setup-dns.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    {
      "source": "/((?!api/|assets/|setup-dns|privacy|terms|connect-intel-|favicon|icons\\.svg|robots\\.txt|manifest\\.json|manifest\\.webmanifest|sw\\.js|workbox-|pwa-|apple-touch-icon|chithi-menu-icon|chithi-push-sw).*)",
      "destination": "/index.html"
    }
  ]
}
