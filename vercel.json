{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd frontend && NODE_OPTIONS=--disable-warning=DEP0040 npm ci",
  "buildCommand": "cd frontend && NODE_OPTIONS=--disable-warning=DEP0040 npm run build",
  "outputDirectory": "site",
  "framework": null,
  "env": {
    "NODE_OPTIONS": "--disable-warning=DEP0040"
  },
  "build": {
    "env": {
      "NODE_OPTIONS": "--disable-warning=DEP0040"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/|assets/).*)", "destination": "/index.html" }
  ]
}
