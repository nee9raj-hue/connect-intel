# Grafana Cloud — copy to .env.grafana.secrets (gitignored)
# Free stack: https://grafana.com/auth/sign-up/create-user
# Prometheus → Details → Remote write URL + Instance ID
# Token: Administration → Cloud access policies → Add token (metrics:write)

GRAFANA_CLOUD_PROMETHEUS_URL=
GRAFANA_CLOUD_PROMETHEUS_USERNAME=
GRAFANA_CLOUD_PROMETHEUS_PASSWORD=
GRAFANA_CLOUD_API_KEY=
GRAFANA_CLOUD_STACK_SLUG=
