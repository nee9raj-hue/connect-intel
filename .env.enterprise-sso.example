# Enterprise SSO secrets — copy to .env.enterprise-sso.local (gitignored)
# Then: npm run sso:connect

# Azure AD (Microsoft Entra)
AUTH_PROVIDER=azure-ad
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# Okta (alternative)
# AUTH_PROVIDER=okta
# OKTA_DOMAIN=your-org.okta.com
# OKTA_CLIENT_ID=
# OKTA_CLIENT_SECRET=

# IdP redirect URI (register in Azure/Okta):
# https://connectintel.net/api/auth/sso/callback
