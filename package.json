{
  "name": "connect-intel",
  "private": true,
  "type": "module",
  "description": "Connect Intel — B2B lead search platform",
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@sentry/node": "^9.47.1",
    "@vercel/functions": "^2.2.13",
    "bullmq": "^5.40.0",
    "ioredis": "^5.4.2",
    "nodemailer": "^7.0.3",
    "web-push": "^3.6.7"
  },
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "deploy:copy": "node scripts/copy-to-root.js",
    "prod:log": "node scripts/production-log.mjs sync",
    "prod:log:list": "node scripts/production-log.mjs list",
    "prod:verify-live": "node scripts/production-log.mjs verify-live",
    "prod:rollback": "node scripts/production-log.mjs rollback",
    "prod:tag": "node scripts/production-log.mjs tag",
    "prod:verify": "node scripts/verify-deploy.mjs",
    "prod:preview": "node scripts/verify-deploy.mjs && npm run preview --prefix frontend -- --host 127.0.0.1 --port 4173",
    "prod:ship": "node scripts/ship-production.mjs",
    "workers": "node workers/index.mjs",
    "meili:backfill": "node scripts/backfill-meilisearch.mjs",
    "pipeline:backfill": "node scripts/backfill-pipeline-leads.mjs",
    "pipeline:sync": "node scripts/pipeline-sync.mjs",
    "deals:sync": "node scripts/deals-sync.mjs",
    "activities:backfill": "node scripts/backfill-pipeline-activities.mjs",
    "activities:indexes": "node scripts/apply-activities-indexes.mjs",
    "enterprise:backfill": "node scripts/backfill-enterprise-crm.mjs",
    "org:sql-backfill": "node scripts/backfill-org-sql.mjs",
    "profiles:sql-backfill": "node scripts/backfill-profiles-sql.mjs",
    "enterprise:setup": "node scripts/run-enterprise-setup.mjs",
    "dash:warm": "node scripts/warm-dashboard-snapshots.mjs",
    "marketing:queue-worker": "node scripts/marketing-queue-worker.mjs",
    "infra:verify": "node scripts/infra-verify.mjs",
    "test": "node --test 'lib/**/*.test.js' 'lib/server/**/*.test.js'",
    "rbac:audit": "node scripts/rbac-handler-audit.mjs",
    "tenant:audit": "node scripts/tenant-audit.mjs",
    "fresh:start": "node scripts/fresh-start-reset.mjs",
    "org:clean": "node scripts/org-crm-clean.mjs",
    "org:roster": "node scripts/org-membership-admin.mjs --roster",
    "org:transfer-admin": "node scripts/org-membership-admin.mjs",
    "railway:connect": "node scripts/railway-connect.mjs",
    "build:standalone": "cd frontend && STANDALONE=1 npm run build",
    "open": "open index.html 2>/dev/null || xdg-open index.html 2>/dev/null || echo 'Open index.html in your browser'"
  }
}
