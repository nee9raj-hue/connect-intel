# Infrastructure V2 P4 — object storage (copy values to Vercel / .env as needed)
# Default production remains STORAGE_PROVIDER=local until you flip.

STORAGE_PROVIDER=r2
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
# STORAGE_PUBLIC_BASE_URL=https://cdn.example.com

# AWS S3 alternative:
# STORAGE_PROVIDER=s3
# STORAGE_REGION=ap-south-1

# MinIO alternative:
# STORAGE_PROVIDER=minio
# STORAGE_ENDPOINT=http://127.0.0.1:9000
# STORAGE_FORCE_PATH_STYLE=true
