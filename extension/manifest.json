{
  "manifest_version": 3,
  "name": "Connect Intel",
  "version": "1.1.1",
  "description": "CRM companion for Gmail and LinkedIn — match pipeline leads, sync email trails, capture profiles, and send from Connect Intel.",
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "cookies", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://connectintel.net/*",
    "https://mail.google.com/*",
    "https://*.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Connect Intel",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["lib/gmailKeyboardIsolate.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["lib/runtime.js", "lib/gmailParticipants.js", "content/pageWidget.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.linkedin.com/*", "https://linkedin.com/*"],
      "js": ["lib/runtime.js", "lib/linkedinCaptureParse.js", "lib/pageCapture.js", "content/captureWidget.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://mail.google.com/*", "https://*.linkedin.com/*", "https://linkedin.com/*"]
    }
  ]
}
