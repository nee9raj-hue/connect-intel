{
  "manifest_version": 3,
  "name": "Connect Intel",
  "version": "1.2.0",
  "description": "CRM companion for Gmail, LinkedIn & contact pages — match leads, sync trails, capture contacts, send from CRM.",
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "cookies", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://connectintel.net/*",
    "https://mail.google.com/*",
    "https://*.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Connect Intel",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["lib/gmailKeyboardIsolate.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["lib/runtime.js", "lib/gmailParticipants.js", "content/pageWidget.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.linkedin.com/*", "https://linkedin.com/*"],
      "js": [
        "lib/runtime.js",
        "lib/linkedinCaptureParse.js",
        "lib/contactPageParse.js",
        "lib/pageCapture.js",
        "content/captureWidget.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": [
        "https://mail.google.com/*",
        "https://connectintel.net/*",
        "https://*.linkedin.com/*",
        "https://linkedin.com/*"
      ],
      "js": [
        "lib/runtime.js",
        "lib/linkedinCaptureParse.js",
        "lib/contactPageParse.js",
        "lib/pageCapture.js",
        "content/captureWidget.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
