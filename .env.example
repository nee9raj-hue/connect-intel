# Copy to frontend/.env for local dev, or add in Vercel → Settings → Environment Variables

# Google Sign-In (required for real Google login on production)
# https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client ID (Web)
# Authorized JavaScript origins: http://localhost:5173, https://your-domain.vercel.app
VITE_GOOGLE_CLIENT_ID=

# GitHub Pages only (optional)
# VITE_BASE_PATH=/your-repo-name/
