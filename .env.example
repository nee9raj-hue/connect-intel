# frontend/.env — local dev only
# Google login (required in production)
# VITE_* is baked into the frontend build; GOOGLE_* is read at runtime via /api/public-config
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Field visit driving distance — free via OpenStreetMap/OSRM (no key required).
# Optional: GOOGLE_MAPS_API_KEY enables paid Google fallback if OSRM geocoding fails.
# GOOGLE_MAPS_API_KEY=
# In Google Cloud → OAuth client → Authorized JavaScript origins add:
# https://connectintel.net  http://localhost:5173
ADMIN_EMAILS=
SESSION_SECRET=

# Persistent database (required for production on Vercel)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
APP_URL=https://connectintel.net
COOKIE_DOMAIN=.connectintel.net

# Chithi PWA push (Web Push / VAPID) — run: node scripts/generate-vapid-keys.mjs
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:invite@connectintel.net

# Team invites from invite@connectintel.net (Resend + DNS at domains.squarespace.com)
INVITE_EMAIL_PROVIDER=resend
EMAIL_FROM=Connect Intel <invite@connectintel.net>
RESEND_API_KEY=

# AI — deploy immediately for better search when data is limited
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# Free mode is ON by default (no paid Apollo/Claude on search)
# ENABLE_PAID_APIS=true

# Solo / one-user deploy — Vercel Hobby + Supabase Free only (default when CRM is solo-free)
# SOLO_FREE_INFRA=true
# Do NOT set: REDIS_URL, MEILI_HOST, ENABLE_PAID_APIS, SENTRY_DSN (unless you accept extra cost)

# Optional paid integrations
# APOLLO_API_KEY=
# ANTHROPIC_API_KEY=

# --- Platform hardening (production CRM scale) ---
# Background email + job queues (Upstash TCP URL required for BullMQ)
# REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# Meilisearch — sub-200ms CRM search (run npm run meili:backfill after enable)
# MEILI_HOST=https://xxx.meilisearch.io
# MEILI_API_KEY=

# Observability
# PROMETHEUS_METRICS=true
# METRICS_SECRET=
# CONNECTINTEL_METRICS_SECRET=   # same as METRICS_SECRET — for Grafana Alloy on Railway
# GRAFANA_CLOUD_PROMETHEUS_URL=
# GRAFANA_CLOUD_PROMETHEUS_USERNAME=
# GRAFANA_CLOUD_PROMETHEUS_PASSWORD=
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Postgres migrations (session pooler — copy host from Supabase dashboard, not aws-0 blindly)
# SUPABASE_DB_PASSWORD=
# DIRECT_URL=postgresql://postgres.hkdrannqcnszfukcqchj:...@aws-N-ap-south-1.pooler.supabase.com:5432/postgres
# DATABASE_URL=postgresql://postgres.hkdrannqcnszfukcqchj:...@aws-N-ap-south-1.pooler.supabase.com:6543/postgres
# SUPABASE_DB_HOST=aws-1-ap-south-1.pooler.supabase.com
# SUPABASE_REGION=ap-south-1
# SUPABASE_ACCESS_TOKEN=

# Per-lead pipeline rows (after supabase/migrations/20260609120000_pipeline_leads.sql)
# USE_PIPELINE_LEADS_TABLE=true

# Railway worker: same vars as above + npm run workers

# Chrome extension — set after Chrome Web Store publish (Team → Integrations install button)
# CHROME_EXTENSION_STORE_URL=https://chromewebstore.google.com/detail/connect-intel/XXXXXXXX

# Gmail OAuth — see GOOGLE-OAUTH-VERIFICATION-RUNBOOK.md and docs/GOOGLE_CASA_AND_VERIFICATION.md
# GOOGLE_OAUTH_ALLOW_CONNECT=true   # private beta / CASA review (test users in Google Cloud)
# GOOGLE_OAUTH_VERIFIED=true        # only after Google approves verification
# GMAIL_ONBOARDING_PROMPT_ENABLED=true  # post-onboarding Gmail modal + getting-started step (requires connect offered)

# --- Infrastructure V2 P4 object storage (opt-in) ---
# STORAGE_PROVIDER=local          # default Docker/MVP
# STORAGE_PROVIDER=r2             # Cloudflare R2
# STORAGE_PROVIDER=s3             # AWS S3
# STORAGE_PROVIDER=minio          # self-hosted MinIO
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_REGION=us-east-1        # R2 uses "auto" when STORAGE_PROVIDER=r2
# STORAGE_ENDPOINT=               # R2/MinIO custom endpoint (R2: set R2_ACCOUNT_ID instead)
# R2_ACCOUNT_ID=
# STORAGE_PUBLIC_BASE_URL=        # optional CDN / public bucket URL
# STORAGE_LOCAL_PATH=./data/uploads
