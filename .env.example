# frontend/.env — local dev only
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
ADMIN_EMAILS=

# Vercel → Project Settings → Environment Variables (then Redeploy)
# ANTHROPIC_API_KEY=sk-ant-api03-...   ← powers Claude lead search (server-side only)
# GOOGLE_CLIENT_ID=...                 ← used for server-side Google token verification
# ADMIN_EMAILS=you@company.com         ← comma-separated admin allowlist
