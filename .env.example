# frontend/.env — local dev only
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
ADMIN_EMAILS=
SESSION_SECRET=

# Persistent database (recommended for production)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI — deploy immediately for better search when data is limited
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# Free mode is ON by default (no paid Apollo/Claude on search)
# ENABLE_PAID_APIS=true

# Optional paid integrations
# APOLLO_API_KEY=
# ANTHROPIC_API_KEY=
