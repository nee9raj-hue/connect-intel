{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "/bin/sh -c 'echo \"$ALLOY_CONFIG_B64\" | base64 -d > /tmp/config.alloy && exec /bin/alloy run /tmp/config.alloy --server.http.listen-addr=0.0.0.0:12345'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
