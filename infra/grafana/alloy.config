// Grafana Alloy — scrape Connect Intel → Grafana Cloud Prometheus
//
// Required env:
//   CONNECTINTEL_METRICS_SECRET  — same as Vercel METRICS_SECRET (or CRON_SECRET)
//   GRAFANA_CLOUD_PROMETHEUS_URL
//   GRAFANA_CLOUD_PROMETHEUS_USERNAME
//   GRAFANA_CLOUD_PROMETHEUS_PASSWORD

prometheus.remote_write "grafana_cloud" {
  endpoint {
    url = env("GRAFANA_CLOUD_PROMETHEUS_URL")

    basic_auth {
      username = env("GRAFANA_CLOUD_PROMETHEUS_USERNAME")
      password = env("GRAFANA_CLOUD_PROMETHEUS_PASSWORD")
    }
  }
}

prometheus.scrape "connectintel" {
  targets = [{
    __address__ = "connectintel.net",
    __scheme__  = "https",
  }]

  scheme        = "https"
  metrics_path  = "/api/metrics"
  params = {
    secret = [env("CONNECTINTEL_METRICS_SECRET")],
  }

  scrape_interval = "30s"
  scrape_timeout  = "10s"

  forward_to = [prometheus.remote_write.grafana_cloud.receiver]
}
